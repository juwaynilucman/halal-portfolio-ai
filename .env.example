# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/halal_portfolio

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── ETF configuration ────────────────────────────────────────────────────────
# Number of halal stocks to select from dividend ETFs (SCHD + VYMI)
NUM_DIVIDEND_COMPANIES=30
# Number of halal stocks to select from growth ETF (IVW)
NUM_GROWTH_COMPANIES=20

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic model ID for the RAG chain and evaluation judge
LLM_MODEL=claude-sonnet-4-6

# ── Optional: Zoya API ───────────────────────────────────────────────────────
# Uncomment and fill in when Zoya integration is implemented
# ZOYA_API_KEY=your-zoya-api-key
